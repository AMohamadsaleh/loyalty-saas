rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Merchants: only owner can read/write their own doc
    match /merchants/{merchantId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
    }

    // Customers: merchants can read; no client writes (Admin SDK only)
    match /customers/{customerId} {
      allow read: if request.auth != null
                  && request.auth.token.role == 'merchant';
      allow write: if false;
    }

    // Memberships: merchant who owns the membership can read; no client writes
    match /memberships/{membershipId} {
      allow read: if request.auth != null
                  && request.auth.token.merchantId == resource.data.merchantId;
      allow write: if false;
    }

    // Transactions: merchant can read their own; no client writes
    match /transactions/{txId} {
      allow read: if request.auth != null
                  && request.auth.token.merchantId == resource.data.merchantId;
      allow write: if false;
    }
  }
}
