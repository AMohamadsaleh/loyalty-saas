rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Stamp template images: public read, no client write (uploaded via console/admin)
    match /stamps/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Merchant logos: public read, only the merchant owner can write
    match /logos/{merchantId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.merchantId == merchantId;
    }

    // PassKit stamp images: public read so PassKit servers can fetch the URL, merchant-owner write
    match /passkit-images/{merchantId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == merchantId;
    }
  }
}
